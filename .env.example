# ===== Konfigurasi Mirror =====

# Hostname situs asli yang akan di-mirror (tanpa protokol).
ORIGIN_HOST=hchk.cards

# Protokol situs asli: http atau https
ORIGIN_PROTOCOL=https

# (Opsional) URL publik mirror kamu, contoh: https://chkr.one
# Jika kosong, akan dideteksi otomatis dari header request (Host + X-Forwarded-Proto).
# Set ini di Railway/Render/VPS agar canonical & sitemap selalu benar.
PUBLIC_URL=https://chkr.one

# Port server (Railway/Render mengisi otomatis lewat env PORT)
PORT=8080

# Aktifkan paksa indexing: hapus header/meta noindex dari origin (true/false)
FORCE_INDEXABLE=true

# Aktifkan injeksi script pengaktif klik-kanan (true/false)
ENABLE_RIGHT_CLICK=true
